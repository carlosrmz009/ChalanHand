void setup() {
  matrix.begin();

  for (int i = 0; i < 5; i++) {
    fingers[i].attach(fingerPins[i]);
    
    
    matrix.renderBitmap(numFrames[i], 8, 12);

    fingers[i].write(180);
    delay(400);
    fingers[i].write(90);
    delay(400); 
    fingers[i].write(0);
    delay(400);
  }

  matrix.renderBitmap(okFrame, 8, 12);
}

